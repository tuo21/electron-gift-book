{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "电子礼金簿",
  "version": "1.10.2",
  "identifier": "com.giftbook.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "vue-tsc && vite build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "电子礼金簿",
        "width": 1550,
        "height": 960,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
